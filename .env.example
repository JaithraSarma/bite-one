# Copy to .env and fill in. .env is gitignored — never commit real values.

# Your personal Anthropic API key. Lives ONLY here (local LiteLLM config).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# LiteLLM proxy admin key (generate a long random string)
LITELLM_MASTER_KEY=sk-master-REPLACE_ME
# Salt used by LiteLLM to encrypt stored keys (generate once, never change)
LITELLM_SALT_KEY=sk-salt-REPLACE_ME

# Postgres password for LiteLLM's key/spend database
LITELLM_DB_PASSWORD=REPLACE_ME

# Open WebUI session secret
WEBUI_SECRET_KEY=REPLACE_ME

# Virtual key for Open WebUI ("spec", $2 budget). Created by
# scripts/create-virtual-keys.ps1 after the stack is up — paste it here,
# then: docker compose up -d open-webui
LITELLM_SPEC_KEY=
